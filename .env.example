PORT=
MONGO_URI=
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
FFMPEG_PATH=
MAIL_USER=
MAIL_PASS=
GOOGLE_GEMINI_API_KEY=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=
GOOGLE_TRANSLATE_KEY=
ARGOS_TRANSLATE_URL=https://minhnguyenminj-quick-translate.hf.space
REDIS_URL=
FRONTEND_URL=

# VNPay (sandbox) — đăng ký tại https://sandbox.vnpayment.vn
VNPAY_TMN_CODE=
VNPAY_HASH_SECRET=
VNPAY_URL=https://sandbox.vnpayment.vn/paymentv2/vnpayment.html
VNPAY_RETURN_URL=

# MoMo (sandbox) — credentials công khai dùng chung trong sample của MoMo
# (https://github.com/momo-wallet/payment), copy thẳng sang .env để chạy thử.
# Nếu cần merchant riêng thì đăng ký tại https://developers.momo.vn
MOMO_PARTNER_CODE=MOMO
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=
MOMO_RETURN_URL=
MOMO_IPN_URL=

# Stripe — lấy test key tại https://dashboard.stripe.com/test/apikeys
# WEBHOOK_SECRET: chạy `stripe listen --forward-to localhost:9090/api/payments/stripe/webhook`
# rồi copy chuỗi `whsec_...` mà CLI in ra.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_RETURN_URL=
STRIPE_CURRENCY=vnd

// Vertex AI API Key
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_LOCATION=us-central1


// Stripe API Keys
#Stripe
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_RETURN_URL=
STRIPE_CURRENCY=

// Langfuse API Keys
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_DASHBOARD_URL=
AI_COST_USD_TO_VND_RATE=
# Set DEBUG locally when diagnosing missing Langfuse trace exports.
LANGFUSE_LOG_LEVEL=
