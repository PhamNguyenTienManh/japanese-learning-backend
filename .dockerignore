# Git and local editor metadata
.git
.gitignore
.vscode

# Dependency and build output directories are recreated inside Docker.
node_modules
dist
coverage
build

# Local environment files and secrets must never enter the Docker build context.
.env
.env.*
.env_*
!.env.example
credentials.json

# Runtime/generated files
pronounce_output
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Local OS files
.DS_Store
Thumbs.db

# Docker metadata not needed inside the image.
docker-compose*.yml
